# MongoDB Atlas (required for persisted data)
MONGODB_URI=
# Default matches apps/web Mongo helper. Set to your existing DB name (e.g. it_advisory) if you are not migrating data.
MONGODB_DB_NAME=techmd

# Optional pool tuning (Railway long-lived Node defaults shown in src/lib/mongodb.ts)
# MONGODB_MAX_POOL_SIZE=50
# MONGODB_MIN_POOL_SIZE=5
# MONGODB_MAX_IDLE_TIME_MS=60000
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Canonical public app URL for web and mobile wrappers.
# In production, set this to the hosted HTTPS domain that browsers and Capacitor apps should open.
# In local development, point it at the local Next.js server URL you actually use.
# Also used for absolute metadata and /api/admin/login redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional public API origin override for wrappers or split-origin setups.
# Leave unset for normal same-origin web deploys on Railway.
# When set, client fetches and form posts use this hosted origin instead of relative `/api/*`.
# NEXT_PUBLIC_API_BASE_URL=https://your-app.up.railway.app

# Guided quiz intake (step 1): structured diagnostic rounds — requires OpenAI on cache miss
# OPENAI_API_KEY=
# OPENAI_DIAGNOSTIC_MODEL=gpt-4o-mini (use openai.chat — avoid Responses-only routing from openai())

# Diagnostic round cache (MongoDB): exact hash first, then Atlas Vector Search on `embedding` when configured.
# Bump DIAGNOSTIC_CACHE_VERSION after prompt or embedding-model changes.
# DIAGNOSTIC_CACHE_VERSION=1
# DIAGNOSTIC_CACHE_DISABLED=1
#
# Semantic similarity (requires Atlas Vector Search index on collection `diagnostic_round_cache`; same name as env).
# Embeddings use OPENAI_API_KEY (1536 dims default for text-embedding-3-small).
# DIAGNOSTIC_CACHE_VECTOR_INDEX_NAME=diagnostic_round_cache_vector
# DIAGNOSTIC_CACHE_VECTOR_MIN_SCORE=0.88
# DIAGNOSTIC_CACHE_VECTOR_NUM_CANDIDATES=200
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536
# DIAGNOSTIC_CACHE_SEMANTIC_DISABLED=1
#
# Diagnostic cache debug UI + `_diagnosticDebug` JSON are controlled from Admin → Settings (MongoDB `app_settings`).

# Optional: when set (min 16 chars), marketing quiz URLs use an AES-256-GCM opaque `?sessionId=` token instead of the raw Mongo ObjectId.
# QUIZ_SESSION_URL_SECRET=
# When unset in production, /admin and /api/admin return 503. In development it is allowed open.
ADMIN_TOKEN=

# Stronger model for /admin/advisor (separate from OPENAI_DIAGNOSTIC_MODEL).
# OPENAI_ADVISOR_MODEL=gpt-4.1

# Payment gateway credentials (encrypted at rest in MongoDB `payment_settings`).
# Required before saving gateway API keys in Admin → Settings → Payments (min 32 characters).
# PAYMENT_CREDENTIALS_MASTER_KEY=

# Optional: protect POST /api/cron/payment-holds (expires pay-after-hold reservations).
# CRON_SECRET=
